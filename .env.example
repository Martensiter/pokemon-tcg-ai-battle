# Collector configuration -- copy to .env and fill in. NEVER commit your .env.
# All secrets come from the environment only; nothing here is read from a
# committed file in production (cloud/CI inject KAGGLE_USERNAME / KAGGLE_KEY).

# --- Kaggle credentials (REQUIRED for real collection) ---
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_token

# --- Competition / dataset ---
COLLECTOR_COMPETITION=pokemon-tcg-ai-battle
# Canonical store: a PRIVATE Kaggle Dataset (owner/name). Used when COLLECTOR_SINK=kaggle.
DATASET_SLUG=your_username/ptcg-ladder-replays

# --- Collection target / strategy ---
COLLECTOR_TOP_N=10
# Optional: prioritise specific team/agent name substrings (comma separated).
COLLECTOR_TARGET_TEAMS=
# Cap episodes per submission per pass (0 = unlimited).
COLLECTOR_EPISODES_PER_SUB=0

# --- Rate limiting / backoff (replay endpoint is server-throttled) ---
COLLECTOR_RPS=0.2
COLLECTOR_MAX_RETRIES=6
COLLECTOR_BACKOFF_BASE=2.0
COLLECTOR_BACKOFF_CAP=120.0
COLLECTOR_REQUEST_TIMEOUT=120.0

# --- Output policy ---
# local = write npz chunks to disk for offline training; kaggle = also publish a Dataset version.
COLLECTOR_SINK=local
COLLECTOR_SAVE_VALUE=true
COLLECTOR_SAVE_META=true
# Raw replay JSON is discarded by default (saves space); opt in to keep it.
COLLECTOR_KEEP_RAW=false
COLLECTOR_CHUNK_SIZE=200
COLLECTOR_LOOP_INTERVAL=900

# --- Paths ---
COLLECTOR_DATA_DIR=collector_data
COLLECTOR_STATE_DIR=collector_state
